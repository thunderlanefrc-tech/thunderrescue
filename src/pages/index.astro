---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Thunder Rescue | Fundacja Ratownictwa Motocyklowego">

  <!-- Fullscreen background image — slides up on intro -->
  <div class="bg-layer" id="bg-layer" aria-hidden="true">
    <img src="/images/background.png" alt="" class="bg-img" draggable="false" />
  </div>

  <!-- Dark overlay behind card -->
  <div class="bg-overlay" id="bg-overlay" aria-hidden="true"></div>

  <!-- Main card — rises from below -->
  <div class="page-wrapper">
    <main class="card" id="main-card">

      <!-- Logo -->
      <div class="logo-wrapper reveal-item" id="logo-wrapper">
        <div class="logo-ring" aria-hidden="true"></div>
        <img src="/images/logo.png" alt="Thunder Rescue" class="logo-img" draggable="false" />
      </div>

      <!-- Name & tagline -->
      <div class="identity reveal-item">
        <h1 class="org-name">Thunder Rescue</h1>
        <p class="org-tagline">Fundacja Ratownictwa Motocyklowego</p>
      </div>

      <!-- Description -->
      <p class="bio reveal-item">
        Thunder Rescue to fundacja ratownictwa motocyklowego, której misją jest niesienie pomocy oraz promowanie bezpieczeństwa. Tworzymy zespół ludzi z pasją, którzy nieustannie rozwijają swoje umiejętności, aby skutecznie wspierać osoby potrzebujące pomocy.
        <br /><br />
        Zajmujemy się zabezpieczeniami medycznymi imprez masowych, wydarzeń sportowych i kulturalnych oraz prowadzimy szkolenia z zakresu pierwszej pomocy. Działamy z zaangażowaniem, profesjonalizmem i gotowością do niesienia pomocy tam, gdzie jest ona najbardziej potrzebna.
      </p>

      <!-- Social media links -->
      <section class="social-section reveal-item">
        <h2 class="section-label">Social Media</h2>
        <div class="social-grid">

          <a href="https://www.facebook.com/profile.php?id=61591382394810" target="_blank" rel="noopener noreferrer" class="link-card" aria-label="Facebook">
            <!-- Facebook -->
            <svg class="link-icon" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            <span>Facebook</span>
          </a>

          <a href="https://www.instagram.com/thunder.rescue/" target="_blank" rel="noopener noreferrer" class="link-card" aria-label="Instagram">
            <!-- Instagram -->
            <svg class="link-icon" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.791-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
            <span>Instagram</span>
          </a>

          <a href="https://www.tiktok.com/@thunder_rescue" target="_blank" rel="noopener noreferrer" class="link-card" aria-label="TikTok">
            <!-- TikTok -->
            <svg class="link-icon" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5 20.1a6.34 6.34 0 0 0 10.86-4.43v-7a8.16 8.16 0 0 0 4.77 1.52v-3.4a4.85 4.85 0 0 1-1-.1z"/></svg>
            <span>TikTok</span>
          </a>

          <a href="https://x.com/Thunder_Rescue_" target="_blank" rel="noopener noreferrer" class="link-card" aria-label="Twitter / X">
            <!-- X -->
            <svg class="link-icon" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            <span>Twitter / X</span>
          </a>

          <a href="https://www.youtube.com/@Thunder_Rescue" target="_blank" rel="noopener noreferrer" class="link-card link-card--wide" aria-label="YouTube">
            <!-- YouTube -->
            <svg class="link-icon" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
            <span>YouTube</span>
          </a>

        </div>
      </section>

      <!-- Contact boxes -->
      <section class="contact-section reveal-item">
        <h2 class="section-label">Kontakt</h2>
        <div class="contact-grid">
          <a href="mailto:kontakt@thunderrescue.com" class="contact-card">
            <svg class="contact-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            <span>kontakt@thunderrescue.com</span>
          </a>
          <a href="tel:+48514680070" class="contact-card">
            <svg class="contact-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.59 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            <span>+48 514 680 070</span>
          </a>
        </div>
      </section>

    </main>
  </div>

</Layout>

<style>
  /* ── Background layer ── */
  .bg-layer {
    position: fixed;
    inset: 0;
    z-index: 0;
    will-change: transform;
    transform: translateY(0);
    transition: transform 1.2s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .bg-layer.shifted {
    transform: translateY(-18%);
  }

  .bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    pointer-events: none;
    user-select: none;
  }

  /* ── Dark overlay ── */
  .bg-overlay {
    position: fixed;
    inset: 0;
    z-index: 1;
    background: rgba(5, 3, 12, 0);
    transition: background 1.2s ease;
    pointer-events: none;
  }

  .bg-overlay.active {
    background: rgba(5, 3, 12, 0.55);
  }

  /* ── Page wrapper ── */
  .page-wrapper {
    position: relative;
    z-index: 2;
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 40px 16px;
    padding-top: max(40px, env(safe-area-inset-top, 40px));
    padding-bottom: max(40px, env(safe-area-inset-bottom, 40px));
  }

  /* ── Card ── */
  .card {
    width: 100%;
    max-width: 520px;
    padding: 44px 36px;
    background: rgba(8, 4, 18, 0.78);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border: 1px solid rgba(220, 38, 38, 0.25);
    border-radius: 28px;
    box-shadow:
      0 0 60px rgba(220, 38, 38, 0.08),
      0 30px 60px -15px rgba(0, 0, 0, 0.7);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0;

    /* Intro: starts off-screen below */
    transform: translateY(110vh);
    opacity: 0;
    transition:
      transform 1.2s cubic-bezier(0.25, 0.46, 0.45, 0.94),
      opacity 0.4s ease;
    will-change: transform, opacity;
  }

  .card.visible {
    transform: translateY(0);
    opacity: 1;
  }

  /* ── Logo ── */
  .logo-wrapper {
    position: relative;
    margin-bottom: 28px;
    width: 180px;
    height: 180px;
    border-radius: 50%;
    animation: float 4s ease-in-out infinite;
  }

  .logo-ring {
    position: absolute;
    inset: -4px;
    border-radius: 50%;
    background: conic-gradient(from 0deg, #dc2626, #991b1b, #b91c1c, #ef4444, #dc2626);
    opacity: 0.7;
    animation: spin 8s linear infinite;
  }

  .logo-img {
    position: relative;
    width: 100%;
    height: 100%;
    border-radius: 50%;
    object-fit: cover;
    z-index: 1;
    pointer-events: none;
    user-select: none;
    background: #0a0008;
    box-shadow: 0 0 40px rgba(220, 38, 38, 0.3);
  }

  @keyframes float {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-10px); }
  }

  @keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  /* ── Identity ── */
  .identity {
    margin-bottom: 20px;
  }

  .org-name {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 34px;
    font-weight: 800;
    letter-spacing: -0.02em;
    background: linear-gradient(135deg, #ef4444 0%, #dc2626 40%, #f87171 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 6px;
    line-height: 1.1;
  }

  .org-tagline {
    font-size: 13px;
    font-weight: 500;
    color: #94a3b8;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  /* ── Bio ── */
  .bio {
    font-size: 14px;
    line-height: 1.75;
    color: #cbd5e1;
    margin-bottom: 32px;
    text-align: center;
  }

  /* ── Section label ── */
  .section-label {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: #64748b;
    margin-bottom: 14px;
    position: relative;
    display: inline-block;
  }

  .section-label::after {
    content: '';
    display: block;
    width: 32px;
    height: 2px;
    background: linear-gradient(90deg, #dc2626, #ef4444);
    border-radius: 1px;
    margin-top: 6px;
    box-shadow: 0 0 8px rgba(220, 38, 38, 0.5);
  }

  /* ── Social section ── */
  .social-section {
    width: 100%;
    margin-bottom: 24px;
  }

  .social-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 10px;
  }

  .link-card {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 14px 18px;
    min-height: 52px;
    background: rgba(220, 38, 38, 0.07);
    border: 1px solid rgba(220, 38, 38, 0.18);
    border-radius: 14px;
    color: white;
    font-size: 14px;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    overflow: hidden;
  }

  .link-card--wide {
    grid-column: 1 / -1;
  }

  .link-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, transparent, rgba(220, 38, 38, 0.08), transparent);
    opacity: 0;
    transition: opacity 0.4s ease;
    pointer-events: none;
  }

  .link-card:hover::before {
    opacity: 1;
  }

  .link-card:hover {
    background: rgba(220, 38, 38, 0.16);
    border-color: rgba(220, 38, 38, 0.45);
    transform: translateY(-3px) scale(1.02);
    box-shadow: 0 12px 30px rgba(220, 38, 38, 0.18);
  }

  .link-card:active {
    transform: translateY(-1px) scale(0.98);
  }

  .link-icon {
    width: 22px;
    height: 22px;
    flex-shrink: 0;
    color: #f87171;
  }

  /* ── Contact section ── */
  .contact-section {
    width: 100%;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 10px;
  }

  .contact-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 18px 14px;
    background: rgba(22, 163, 74, 0.12);
    border: 1px solid rgba(22, 163, 74, 0.3);
    border-radius: 14px;
    color: #86efac;
    font-size: 12px;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.3s ease;
    word-break: break-all;
    text-align: center;
  }

  .contact-card:hover {
    background: rgba(22, 163, 74, 0.22);
    border-color: rgba(22, 163, 74, 0.5);
    transform: translateY(-3px);
    box-shadow: 0 10px 25px rgba(22, 163, 74, 0.15);
  }

  .contact-icon {
    width: 22px;
    height: 22px;
    color: #4ade80;
    flex-shrink: 0;
  }

  /* ── Reveal animation ── */
  .reveal-item {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.5s ease, transform 0.5s ease;
  }

  .reveal-item.revealed {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── Mobile ── */
  @media (max-width: 480px) {
    .page-wrapper {
      padding: 24px 12px;
    }

    .card {
      padding: 32px 20px;
      border-radius: 22px;
    }

    .logo-wrapper {
      width: 150px;
      height: 150px;
      margin-bottom: 22px;
    }

    .org-name {
      font-size: 28px;
    }

    .social-grid {
      grid-template-columns: 1fr;
    }

    .link-card--wide {
      grid-column: 1;
    }

    .contact-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const bgLayer = document.getElementById('bg-layer');
    const bgOverlay = document.getElementById('bg-overlay');
    const card = document.getElementById('main-card');
    const revealItems = document.querySelectorAll('.reveal-item');

    // Phase 1: show background for 600ms, then start slide
    setTimeout(() => {
      bgLayer?.classList.add('shifted');
      bgOverlay?.classList.add('active');

      // Phase 2: card slides up from bottom (slight delay so it feels sequential)
      setTimeout(() => {
        card?.classList.add('visible');
      }, 150);

      // Phase 3: reveal items sequentially after card arrives
      revealItems.forEach((el, i) => {
        setTimeout(() => {
          el.classList.add('revealed');
        }, 1100 + i * 220);
      });

    }, 600);
  });
</script>
